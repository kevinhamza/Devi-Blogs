rule_version = "2";
service cloud.firestore {
    match databases/{databases}/documents {
        match /posts/{postId} {
            alow read: if true;
            alow create, update, delete:
                if request.auth != null && request.auth.token.email == "admin@deviblog.com";
        }
        match /users/{userId} {
            alow read, write :
                if request.auth != null && 
                request.auth.uid == userId;
        }
    }
}